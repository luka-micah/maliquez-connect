generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String           @id @default(cuid())
  firstName            String
  lastName             String
  email                String           @unique
  phone                String?
  password             String
  avatar               String?
  role                 Role             @default(USER)
  isVerified           Boolean          @default(false)
  status               UserStatus       @default(ACTIVE)
  providerProfile      Json?
  subscribedToNewsletter Boolean @default(false)
  refreshToken         String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  comparisons          Comparison[]
  favorites            Favorite[]
  listings             Listing[]
  notifications        Notification[]
  recommendations      Recommendation[]
  reviews              Review[]
  searchHistories      SearchHistory[]
  conversationsAsUser  Conversation[]   @relation("conversationUser")
  conversationsAsProvider Conversation[] @relation("conversationProvider")
  messages             Message[]
  agentProfile         AgentProfile?
  providerOnboarding   ProviderOnboarding?
  providerDocuments    ProviderDocument[]
  auditLogs            AuditLog[]

  @@map("users")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String?   @unique
  description String?
  icon        String?
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  listings    Listing[]

  @@map("categories")
}

model Listing {
  id              String             @id @default(cuid())
  title           String
  slug            String?            @unique
  description     String
  categoryId      String
  ownerId         String
  sector          Sector
  contact         Json?
  location        Json?
  images          String[]
  imageMetadata   Json?
  features        String[]
  pricing         Json?
  operatingHours  Json?
  averageRating   Float              @default(0)
  reviewCount     Int                @default(0)
  verified        VerificationStatus @default(UNVERIFIED)
  status          ListingStatus      @default(PENDING)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  favorites       Favorite[]
  category        Category           @relation(fields: [categoryId], references: [id])
  owner           User               @relation(fields: [ownerId], references: [id])
  recommendations Recommendation[]
  reviews         Review[]
  conversations   Conversation[]

  @@index([status])
  @@index([sector])
  @@index([categoryId])
  @@index([ownerId])
  @@index([averageRating])
  @@map("listings")
}

model Review {
  id           String       @id @default(cuid())
  userId       String
  listingId    String
  rating       Int
  review       String?
  helpfulCount Int          @default(0)
  status       ReviewStatus @default(APPROVED)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  listing      Listing      @relation(fields: [listingId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([userId, listingId])
  @@index([listingId])
  @@index([userId])
  @@map("reviews")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, listingId])
  @@index([userId])
  @@map("favorites")
}

model Comparison {
  id         String   @id @default(cuid())
  userId     String
  listingIds String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("comparisons")
}

model Recommendation {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  reason    String?
  score     Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  listing   Listing  @relation(fields: [listingId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([score])
  @@map("recommendations")
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  keyword   String?
  filters   Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("search_histories")
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  title          String
  message        String
  read           Boolean          @default(false)
  type           NotificationType @default(SYSTEM)
  referenceId    String?
  referenceModel String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

model Conversation {
  id            String    @id @default(cuid())
  listingId     String
  userId        String
  providerId    String
  lastMessage   String?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  listing       Listing   @relation(fields: [listingId], references: [id])
  user          User      @relation(fields: [userId], references: [id], name: "conversationUser")
  provider      User      @relation(fields: [providerId], references: [id], name: "conversationProvider")
  messages      Message[]

  @@unique([userId, providerId, listingId])
  @@index([listingId])
  @@index([userId])
  @@index([providerId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([conversationId, createdAt])
  @@map("messages")
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  image       String?
  date        DateTime?
  time        String?
  location    String?
  linkUrl     String?
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  registrations EventRegistration[]

  @@map("events")
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  firstName String
  lastName  String
  email     String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, email])
  @@map("event_registrations")
}

model Ad {
  id        String    @id @default(cuid())
  title     String
  image     String
  linkUrl   String?
  status    String    @default("ACTIVE")
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ads")
}

model AgentProfile {
  id            String      @id @default(cuid())
  userId        String      @unique
  name          String
  referralCode  String      @unique
  phone         String?
  assignedState String?
  assignedLGA   String?
  status        AgentStatus @default(ACTIVE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerOnboardings ProviderOnboarding[]
  outreachActivities  OutreachActivity[]
  auditLogs           AuditLog[]

  @@index([referralCode])
  @@index([userId])
  @@index([status])
  @@map("agent_profiles")
}

model ProviderOnboarding {
  id               String           @id @default(cuid())
  providerId       String           @unique
  agentId          String
  businessName     String
  category         String?
  sector           String?
  contactPerson    String
  phoneNumber      String
  email            String
  whatsappNumber   String?
  address          String?
  state            String?
  lga              String?
  description      String?
  gpsCoordinates   Json?
  website          String?
  socialLinks      Json?
  onboardingStatus OnboardingStatus @default(PROSPECT)
  onboardingNotes  String?
  invitedAt        DateTime?
  claimedAt        DateTime?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectedReason   String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  agent               AgentProfile        @relation(fields: [agentId], references: [id])
  provider            User                @relation(fields: [providerId], references: [id])
  outreachActivities  OutreachActivity[]  @relation("ActivityProvider")
  onboardingActivities OutreachActivity[] @relation("ActivityOnboarding")
  invitationTokens    InvitationToken[]    @relation("InvitationProvider")
  documents           ProviderDocument[]

  @@index([agentId])
  @@index([providerId])
  @@index([onboardingStatus])
  @@index([email])
  @@index([state])
  @@index([lga])
  @@map("provider_onboardings")
}

model ProviderDocument {
  id            String       @id @default(cuid())
  providerId    String
  onboardingId  String
  documentType  DocumentType
  fileUrl       String
  publicId      String?
  fileName      String?
  status        String       @default("PENDING")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  onboarding ProviderOnboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  provider   User               @relation(fields: [providerId], references: [id])

  @@index([onboardingId])
  @@index([providerId])
  @@map("provider_documents")
}

model OutreachActivity {
  id            String       @id @default(cuid())
  agentId       String
  providerId    String
  onboardingId  String?
  activityType  ActivityType
  note          String?
  nextFollowUp  DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  agent      AgentProfile        @relation(fields: [agentId], references: [id])
  provider   ProviderOnboarding  @relation("ActivityProvider", fields: [providerId], references: [id])
  onboarding ProviderOnboarding? @relation("ActivityOnboarding", fields: [onboardingId], references: [id])

  @@index([agentId])
  @@index([providerId])
  @@index([nextFollowUp])
  @@map("outreach_activities")
}

model AuditLog {
  id            String      @id @default(cuid())
  userId        String?
  agentId       String?
  action        AuditAction
  entityType    String
  entityId      String?
  previousValue Json?
  newValue      Json?
  ipAddress     String?
  createdAt     DateTime    @default(now())

  user  User?         @relation(fields: [userId], references: [id])
  agent AgentProfile? @relation(fields: [agentId], references: [id])

  @@index([userId])
  @@index([agentId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model InvitationToken {
  id            String   @id @default(cuid())
  email         String
  token         String   @unique
  providerId    String
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime @default(now())

  provider ProviderOnboarding @relation("InvitationProvider", fields: [providerId], references: [id])

  @@index([token])
  @@index([email])
  @@index([expiresAt])
  @@map("invitation_tokens")
}

enum Role {
  USER
  PROVIDER
  AGENT
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum VerificationStatus {
  UNVERIFIED
  VERIFIED
  PENDING
}

enum ListingStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Sector {
  Education
  Healthcare
  Hospitality
  Logistics
}

enum NotificationType {
  LISTING
  REVIEW
  SYSTEM
  APPROVAL
  ONBOARDING
}

enum AgentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum OnboardingStatus {
  PROSPECT
  CONTACTED
  INTERESTED
  REGISTERED
  INVITED
  ACCOUNT_CLAIMED
  PROFILE_COMPLETED
  DOCUMENTS_SUBMITTED
  UNDER_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
  SUSPENDED
  INACTIVE
}

enum ActivityType {
  PHONE_CALL
  WHATSAPP
  SMS
  EMAIL
  OFFICE_VISIT
  MEETING
  FOLLOW_UP
  OTHER
}

enum DocumentType {
  CAC_CERTIFICATE
  NATIONAL_ID
  DRIVER_LICENSE
  UTILITY_BILL
  BUSINESS_REGISTRATION
  TAX_CERTIFICATE
  OTHER
}

enum AuditAction {
  AGENT_REGISTRATION
  PROVIDER_REGISTRATION
  STATUS_CHANGE
  APPROVAL
  REASSIGNMENT
  INVITATION
  DOCUMENT_UPLOAD
}
